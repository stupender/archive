{
  "name": "sonic-archive",
  "version": "0.1.0",
  "description": "A personal music archive app inspired by Brian Eno & Peter Chilvers' setup.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:dir": "tsc -b && vite build && electron-builder --dir",
    "preview": "vite preview",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "music-metadata": "^10.5.0",
    "plist": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/plist": "^3.0.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.sonicarchive.app",
    "productName": "Sonic Archive",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
